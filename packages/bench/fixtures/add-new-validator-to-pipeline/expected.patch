diff --git a/src/validators/no-any.ts b/src/validators/no-any.ts
new file mode 100644
index 0000000..24c39bf
--- /dev/null
+++ b/src/validators/no-any.ts
@@ -0,0 +1,8 @@
+import type { Patch, ValidatorResult } from "../pipeline.js";
+
+export function noAnyValidator(patch: Patch): ValidatorResult {
+  if (patch.content.includes(": any") || patch.content.includes("as any")) {
+    return { ok: false, reason: "no-any: patch content must not use ': any' or 'as any'" };
+  }
+  return { ok: true };
+}
