@@ -0,0 +1,25 @@
+import { randomUUID } from "node:crypto";
+
+export type AuditEntry = {
+  eventId: string;
+  action: "create" | "delete";
+  entityId: string;
+  timestamp: number;
+};
+
+const log: AuditEntry[] = [];
+
+export function appendAudit(entry: Omit<AuditEntry, "eventId" | "timestamp">): void {
+  log.push({ eventId: randomUUID(), timestamp: Date.now(), ...entry });
+}
+
+export function queryAudit(filter?: { action?: string; entityId?: string }): AuditEntry[] {
+  let entries = [...log];
+  if (filter?.action) entries = entries.filter((e) => e.action === filter.action);
+  if (filter?.entityId) entries = entries.filter((e) => e.entityId === filter.entityId);
+  return entries.sort((a, b) => a.timestamp - b.timestamp);
+}
+
+export function clearAudit(): void {
+  log.length = 0;
+}
