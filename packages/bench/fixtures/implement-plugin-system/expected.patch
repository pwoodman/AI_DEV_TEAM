   },
 };
+
+registry.register("csv", csvParser);
--- a/src/parsers/json.ts
+++ b/src/parsers/json.ts
@@ -1,5 +1,9 @@
+import { registry } from "../plugin-registry.js";
+
 export type Parser = { parse(input: string): string[] };

 export const jsonParser: Parser = {
   parse(input: string): string[] {
     const arr = JSON.parse(input) as unknown;
     if (!Array.isArray(arr)) throw new Error("expected array");
     return arr.map(String);
   },
 };
+
+registry.register("json", jsonParser);
--- a/src/parsers/xml.ts
+++ b/src/parsers/xml.ts
@@ -1,5 +1,9 @@
+import { registry } from "../plugin-registry.js";
+
 export type Parser = { parse(input: string): string[] };

 export const xmlParser: Parser = {
   parse(input: string): string[] {
     return Array.from(input.matchAll(/<item>(.*?)<\/item>/g)).map((m) => m[1] ?? "");
   },
 };
+
+registry.register("xml", xmlParser);
