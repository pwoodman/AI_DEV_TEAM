   windowMs: number;
 }
 
+interface Bucket {
+  count: number;
+  windowStart: number;
+}
+
 // Wire rate-limiting around the router's handle. Return the modified router.
-export function applyMiddleware(router: Router, _opts: RateLimitOptions): Router {
+export function applyMiddleware(router: Router, opts: RateLimitOptions): Router {
+  const buckets = new Map<string, Bucket>();
+
+  const originalHandle = router.handle;
+
+  router.handle = (req) => {
+    const key = `${req.method} ${req.path}`;
+    const currentTime = now();
+    let bucket = buckets.get(key);
+
+    if (!bucket || currentTime - bucket.windowStart >= opts.windowMs) {
+      bucket = { count: 0, windowStart: currentTime };
+      buckets.set(key, bucket);
+    }
+
+    if (bucket.count >= opts.limit) {
+      return { status: 429, body: "rate limit exceeded" };
+    }
+
+    bucket.count += 1;
+    return originalHandle(req);
+  };
+
   return router;
 }
